// ===== STATE =====
const ALL_IDS = ['p1','p2','p3','p4','p5','p6','i1','i2','i3','i4','i5','i6','i7','i8','i9','i10','i11','i12','i13','i14','i15','i16','i17','f1','f2','f3','a1','a2','a3','a4'];
