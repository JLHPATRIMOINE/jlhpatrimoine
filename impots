<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>JLH Patrimoine — Checklist Déclaration d'impôts 2026</title>
<meta name="description" content="Préparez sereinement votre déclaration d'impôts 2026 avec JLH Patrimoine. Identifiez vos documents fiscaux en quelques minutes."/>
<meta name="robots" content="noindex,nofollow"/>
<meta property="og:title" content="JLH Patrimoine — Checklist Fiscale 2026"/>
<meta property="og:description" content="Aide à la préparation de votre déclaration d'impôts 2026."/>
<meta property="og:type" content="website"/>
<meta name="theme-color" content="#142B45"/>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #142B45;
    --navy-light: #1C3A5A;
    --gold: #92A6BB;
    --gold-light: #ADC0D1;
    --gold-pale: #E8EEF4;
    --cream: #F3F6F9;
    --white: #FFFFFF;
    --text: #142B45;
    --text-mid: #4A6070;
    --text-light: #7A92A6;
    --border: #D0DCE6;
    --green: #2E7D5B;
    --green-pale: #EAF5EF;
    --red: #C0392B;
    --red-pale: #FDECEA;
    --shadow: 0 4px 24px rgba(20,43,69,0.08);
    --shadow-lg: 0 8px 40px rgba(20,43,69,0.12);
    --radius: 12px;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text);font-size:15px;line-height:1.6;min-height:100vh;}

  /* HEADER */
  .header{background:var(--navy);padding:0;position:sticky;top:0;z-index:100;box-shadow:0 2px 20px rgba(0,0,0,0.2);}
  .header-inner{max-width:1100px;margin:0 auto;padding:18px 32px;display:flex;align-items:center;justify-content:space-between;}
  .logo-area{display:flex;align-items:center;gap:14px;}
  .logo-text{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:600;color:var(--white);letter-spacing:0.02em;display:flex;align-items:center;gap:4px;}
  .logo-jlh{font-size:26px;font-weight:700;color:var(--gold);}
  .logo-divider{width:1px;height:28px;background:rgba(255,255,255,0.2);margin:0 14px;}
  .header-badge{font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.5);font-weight:300;}
  .header-year{background:var(--gold);color:var(--navy);font-size:11px;font-weight:500;letter-spacing:0.08em;padding:5px 14px;border-radius:20px;text-transform:uppercase;}

  /* HERO */
  .hero{background:linear-gradient(135deg,var(--navy) 0%,#1C3A5A 60%,#142B45 100%);padding:72px 32px 64px;text-align:center;position:relative;overflow:hidden;}
  .hero::before{content:'';position:absolute;top:-40%;left:-20%;width:600px;height:600px;background:radial-gradient(circle,rgba(146,166,187,0.12) 0%,transparent 70%);pointer-events:none;}
  .hero::after{content:'';position:absolute;bottom:-30%;right:-10%;width:400px;height:400px;background:radial-gradient(circle,rgba(146,166,187,0.08) 0%,transparent 70%);pointer-events:none;}
  .hero-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(146,166,187,0.15);border:1px solid rgba(146,166,187,0.3);color:var(--gold-light);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;padding:6px 16px;border-radius:20px;margin-bottom:24px;font-weight:400;}
  .hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,5vw,56px);font-weight:400;line-height:1.2;color:var(--white);margin-bottom:16px;position:relative;z-index:1;}
  .hero h1 em{font-style:italic;color:var(--gold-light);}
  .hero-sub{font-size:16px;color:rgba(255,255,255,0.65);max-width:520px;margin:0 auto 40px;font-weight:300;line-height:1.7;position:relative;z-index:1;}

  /* PROGRESS */
  .progress-card{background:rgba(255,255,255,0.05);border:1px solid rgba(146,166,187,0.2);border-radius:var(--radius);padding:28px 36px;max-width:620px;margin:0 auto;position:relative;z-index:1;}
  .progress-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;gap:16px;flex-wrap:wrap;}
  .progress-stat{text-align:center;}
  .progress-stat .num{font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:500;color:var(--white);line-height:1;}
  .progress-stat .num.green{color:#5DD89A;}
  .progress-stat .num.red{color:#FF7B6B;}
  .progress-stat .lbl{font-size:11px;color:rgba(255,255,255,0.45);letter-spacing:0.08em;text-transform:uppercase;margin-top:4px;}
  .progress-divider{width:1px;height:40px;background:rgba(255,255,255,0.1);}
  .progress-bar-track{background:rgba(255,255,255,0.1);border-radius:4px;height:6px;overflow:hidden;margin-top:4px;}
  .progress-bar-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--gold),var(--gold-light));transition:width 0.6s cubic-bezier(0.4,0,0.2,1);}
  .progress-pct{font-size:12px;color:var(--gold-light);text-align:right;margin-top:6px;font-weight:500;}

  /* INTRO */
  .intro{max-width:720px;margin:48px auto 0;padding:36px 40px;background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow);border-left:4px solid var(--gold);}
  .intro-title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:500;color:var(--navy);margin-bottom:12px;}
  .intro p{font-size:14px;color:var(--text-mid);line-height:1.75;}
  .intro p+p{margin-top:10px;}
  .intro strong{color:var(--navy);font-weight:500;}

  /* MAIN */
  .main{max-width:1100px;margin:0 auto;padding:56px 32px 80px;}

  /* SECTION LABEL */
  .section-label{display:flex;align-items:center;gap:12px;margin-bottom:20px;margin-top:48px;}
  .section-label:first-child{margin-top:0;}
  .section-icon{width:40px;height:40px;background:var(--navy);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .section-icon svg{width:20px;height:20px;stroke:var(--gold);fill:none;stroke-width:1.8;}
  .section-title{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:500;color:var(--navy);}
  .section-count{margin-left:auto;font-size:12px;color:var(--text-light);background:var(--cream);border:1px solid var(--border);padding:3px 12px;border-radius:20px;white-space:nowrap;}

  /* CARD */
  .cat-card{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:12px;overflow:hidden;border:1px solid var(--border);transition:box-shadow 0.2s;}
  .cat-card:hover{box-shadow:var(--shadow-lg);}
  .cat-header{display:flex;align-items:center;gap:12px;padding:16px 20px;cursor:pointer;user-select:none;border-bottom:1px solid var(--border);transition:border-color 0.2s;}
  .cat-name{font-weight:500;font-size:15px;color:var(--navy);flex:1;}
  .cat-mini-progress{display:flex;align-items:center;gap:8px;}
  .cat-mini-bar{width:60px;height:4px;background:var(--border);border-radius:2px;overflow:hidden;}
  .cat-mini-bar-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--gold),var(--gold-light));transition:width 0.4s;width:0%;}
  .cat-mini-pct{font-size:12px;color:var(--text-light);}
  .cat-chevron{width:20px;height:20px;color:var(--text-light);transition:transform 0.3s;flex-shrink:0;}
  .cat-chevron.open{transform:rotate(180deg);}
  .cat-body{padding:8px 0;}
  .cat-body.closed{display:none;}

  /* SUBCAT */
  .subcat-label{font-size:12px;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);font-weight:500;padding:10px 20px 4px;}

  /* ITEM ROW */
  .item-row{display:flex;align-items:flex-start;gap:12px;padding:10px 20px;border-bottom:1px solid var(--cream);transition:background 0.15s;}
  .item-row:last-child{border-bottom:none;}
  .item-row:hover{background:var(--cream);}
  .item-check-area{display:flex;flex-direction:column;gap:6px;flex-shrink:0;padding-top:2px;}
  .check-btn{display:flex;align-items:center;gap:6px;cursor:pointer;font-size:12px;font-weight:400;color:var(--text-mid);background:none;border:none;padding:0;white-space:nowrap;transition:color 0.15s;}
  .check-btn:hover{color:var(--navy);}
  .check-box{width:18px;height:18px;border-radius:5px;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.15s;background:var(--white);}
  .check-btn.active-have .check-box{background:var(--green);border-color:var(--green);}
  .check-btn.active-missing .check-box{background:var(--red);border-color:var(--red);}
  .check-box svg{width:11px;height:11px;stroke:white;stroke-width:2.5;fill:none;display:none;}
  .check-btn.active-have .check-box svg,.check-btn.active-missing .check-box svg{display:block;}
  .item-content{flex:1;min-width:0;}
  .item-name{font-size:14px;color:var(--text);line-height:1.5;}
  .item-source{font-size:12px;color:var(--text-light);font-style:italic;margin-top:2px;}
  .item-status{display:inline-flex;align-items:center;gap:5px;font-size:11px;padding:3px 10px;border-radius:10px;margin-top:6px;font-weight:500;}
  .item-status.have{background:var(--green-pale);color:var(--green);}
  .item-status.missing{background:var(--red-pale);color:var(--red);}
  .item-status.none{display:none;}
  .comment-toggle{font-size:12px;color:var(--gold);cursor:pointer;background:none;border:none;padding:0;display:flex;align-items:center;gap:4px;font-weight:400;margin-top:6px;}
  .comment-toggle:hover{color:var(--gold-light);}
  .comment-input{margin-top:6px;width:100%;border:1px solid var(--border);border-radius:8px;padding:8px 12px;font-size:13px;color:var(--text);font-family:'DM Sans',sans-serif;resize:none;background:var(--cream);outline:none;transition:border-color 0.2s;min-height:60px;display:none;}
  .comment-input:focus{border-color:var(--gold);}

  /* ACTION BAR */
  .action-bar{position:sticky;bottom:0;background:var(--white);border-top:1px solid var(--border);padding:16px 32px;z-index:50;box-shadow:0 -4px 20px rgba(20,43,69,0.08);}
  .action-bar-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
  .btn{display:inline-flex;align-items:center;gap:8px;padding:11px 22px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;border:none;transition:all 0.2s;white-space:nowrap;letter-spacing:0.01em;}
  .btn svg{width:15px;height:15px;flex-shrink:0;}
  .btn-primary{background:var(--navy);color:var(--white);box-shadow:0 2px 8px rgba(20,43,69,0.25);}
  .btn-primary:hover{background:var(--navy-light);transform:translateY(-1px);box-shadow:0 4px 14px rgba(20,43,69,0.3);}
  .btn-gold{background:var(--gold);color:var(--navy);box-shadow:0 2px 8px rgba(146,166,187,0.3);}
  .btn-gold:hover{background:var(--gold-light);transform:translateY(-1px);box-shadow:0 4px 14px rgba(146,166,187,0.4);}
  .btn-outline{background:transparent;color:var(--navy);border:1.5px solid var(--border);}
  .btn-outline:hover{border-color:var(--navy);background:var(--cream);}

  /* MISSING PANEL */
  .missing-panel{max-width:720px;margin:32px auto 0;background:var(--red-pale);border:1px solid #F5BCBA;border-radius:var(--radius);padding:24px 28px;display:none;}
  .missing-panel h3{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;color:var(--red);margin-bottom:16px;display:flex;align-items:center;gap:8px;}
  .missing-list{list-style:none;}
  .missing-list li{display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid rgba(192,57,43,0.1);font-size:13px;color:#8B1A1A;}
  .missing-list li:last-child{border-bottom:none;}
  .missing-list li::before{content:'';display:block;min-width:6px;height:6px;background:var(--red);border-radius:50%;margin-top:6px;}
  .missing-cat{font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--red);opacity:0.6;margin-left:auto;white-space:nowrap;}

  /* SUCCESS PANEL */
  .success-panel{max-width:720px;margin:32px auto 0;background:var(--green-pale);border:1px solid #9ED8BC;border-radius:var(--radius);padding:24px 28px;display:none;text-align:center;}
  .success-panel h3{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:500;color:var(--green);margin-bottom:8px;}
  .success-panel p{font-size:14px;color:#2E6050;}

  /* FOOTER */
  .footer{background:var(--navy);padding:40px 32px;text-align:center;}
  .footer-logo{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--white);margin-bottom:8px;}
  .footer-logo span{color:var(--gold);}
  .footer-info{font-size:12px;color:rgba(255,255,255,0.35);line-height:1.8;}

  /* RESPONSIVE TABLETTE */
  @media(max-width:900px){
    .main{padding:40px 20px 80px;}
    .header-inner{padding:14px 20px;}
    .cat-mini-progress{display:none;}
    .section-title{font-size:20px;}
  }
  /* RESPONSIVE MOBILE */
  @media(max-width:640px){
    .header-inner{padding:12px 16px;}
    .header-badge{display:none;}
    .logo-divider{display:none;}
    .header-year{font-size:10px;padding:4px 10px;}
    .hero{padding:40px 16px 36px;}
    .hero h1{font-size:clamp(28px,7vw,40px);}
    .hero-sub{font-size:14px;margin-bottom:28px;}
    .progress-card{padding:18px 16px;}
    .progress-stat .num{font-size:28px;}
    .progress-stat .lbl{font-size:10px;}
    .progress-divider{height:30px;}
    .main{padding:24px 12px 100px;}
    .intro{margin:24px 12px 0;padding:20px 16px;}
    .intro-title{font-size:18px;}
    .intro p{font-size:13px;}
    .section-label{margin-top:32px;gap:8px;}
    .section-title{font-size:18px;}
    .section-icon{width:34px;height:34px;border-radius:8px;}
    .section-count{font-size:11px;padding:2px 8px;}
    .cat-header{padding:14px 14px;}
    .cat-name{font-size:13px;}
    .cat-mini-progress{display:none;}
    .item-row{padding:10px 14px;gap:10px;}
    .item-check-area{flex-direction:row;flex-wrap:wrap;gap:8px;padding-top:0;width:100%;}
    .check-btn{font-size:12px;padding:6px 10px;border-radius:6px;background:var(--cream);border:1px solid var(--border);}
    .check-btn.active-have{background:var(--green-pale);color:var(--green);}
    .check-btn.active-missing{background:var(--red-pale);color:var(--red);}
    .item-content{width:100%;}
    .item-name{font-size:13px;}
    .item-source{font-size:11px;}
    .action-bar{padding:10px 12px;}
    .action-bar-inner{justify-content:center;gap:8px;}
    .btn{padding:10px 14px;font-size:12px;}
    .missing-panel{margin:16px 12px 0;padding:16px;}
    .success-panel{margin:16px 12px 0;padding:16px;}
    .footer{padding:28px 16px;}
    .footer-info{font-size:11px;}
  }
  /* TRÈS PETIT MOBILE */
  @media(max-width:380px){
    .btn{padding:8px 10px;font-size:11px;}
    .progress-row{gap:8px;}
    .progress-stat .num{font-size:22px;}
  }
</style>
</head>
<body>

<!-- HEADER -->
<header class="header">
  <div class="header-inner">
    <div class="logo-area">
      <img src="data:image/jpeg;base64," alt="JLH Patrimoine" style="height:38px;display:block;">
      <div class="logo-divider"></div>
      <div class="header-badge">Aides documentaires</div>
    </div>
    <div class="header-year">Déclaration d'impôts 2026</div>
  </div>
</header>

<!-- HERO -->
<section class="hero">
  <h1>Préparez facilement<br><em>vos pièces fiscales</em></h1>
  <p class="hero-sub">Cette checklist vous permet d'identifier en quelques minutes les documents utiles pour votre rendez-vous d'aide à la déclaration fiscale.</p>
  <div class="progress-card">
    <div class="progress-row">
      <div class="progress-stat"><div class="num" id="total-count">30</div><div class="lbl">Documents</div></div>
      <div class="progress-divider"></div>
      <div class="progress-stat"><div class="num green" id="have-count">0</div><div class="lbl">Prêts</div></div>
      <div class="progress-divider"></div>
      <div class="progress-stat"><div class="num red" id="missing-count">0</div><div class="lbl">À retrouver</div></div>
      <div class="progress-divider"></div>
      <div class="progress-stat"><div class="num" id="pending-count">30</div><div class="lbl">Non renseignés</div></div>
    </div>
    <div class="progress-bar-track"><div class="progress-bar-fill" id="progress-fill" style="width:0%"></div></div>
    <div class="progress-pct" id="progress-pct">0% renseigné</div>
  </div>
</section>

<!-- INTRO -->
<div style="max-width:720px;margin:0 auto;padding:0 32px;">
  <div class="intro">
    <div class="intro-title">Comment utiliser cette checklist* ?</div>
    <p>Cette page a été conçue pour vous aider à préparer sereinement votre rendez-vous fiscal avec votre conseiller <strong>JLH PATRIMOINE</strong>. Parcourez chaque catégorie et indiquez simplement si vous possédez déjà le document ou s'il reste à retrouver.</p>
    <p>Une fois terminé, <strong>téléchargez votre récapitulatif en PDF</strong> pour l'avoir sous la main lors de votre rendez-vous avec votre conseiller <strong>JLH PATRIMOINE</strong>.</p>
    <p style="margin-top:12px;"><strong>Ces documents sont à déposer dans votre coffre fort sécurisé via votre espace Wealthcome dans le dossier « Déclaration d'impôts ».</strong></p>
    <p style="font-size:11px;color:var(--text-light);margin-top:12px;font-style:italic;">* Liste non exhaustive</p>
  </div>
</div>

<!-- MISSING PANEL -->
<div id="missing-panel" class="missing-panel" style="max-width:720px;margin:32px auto 0;">
  <h3>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    Documents à retrouver
  </h3>
  <ul class="missing-list" id="missing-list"></ul>
</div>

<!-- SUCCESS PANEL -->
<div id="success-panel" class="success-panel" style="max-width:720px;margin:32px auto 0;">
  <h3>Préparation validée ✓</h3>
  <p>Votre checklist a été sauvegardée. Téléchargez votre récapitulatif PDF pour l'apporter lors de votre rendez-vous avec JLH Patrimoine.</p>
</div>

<!-- MAIN CHECKLIST -->
<main class="main">

  <!-- ===== INFORMATIONS PERSONNELLES ===== -->
  <div class="section-label">
    <div class="section-icon">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
    </div>
    <div class="section-title">Informations personnelles</div>
    <div class="section-count">7 pièces</div>
  </div>

  <div class="cat-card">
    <div class="cat-header" onclick="toggleCard(this)">
      <div class="cat-name">Numéro fiscal, revenus et justificatifs</div>
      <div class="cat-mini-progress">
        <div class="cat-mini-bar"><div class="cat-mini-bar-fill" id="mini-perso"></div></div>
        <span class="cat-mini-pct" id="mpct-perso">0%</span>
      </div>
      <div class="cat-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></div>
    </div>
    <div class="cat-body closed">
      <!-- p1 -->
      <div class="item-row" id="row-p1">
        <div class="item-check-area">
          <button type="button" class="check-btn" id="have-p1" onclick="toggleStatus('p1','have')"><div class="check-box"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><span>J'ai ce document</span></button>
          <button type="button" class="check-btn" id="missing-p1" onclick="toggleStatus('p1','missing')"><div class="check-box"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div><span>À retrouver</span></button>
        </div>
        <div class="item-content">
          <div class="item-name">Numéro fiscal + Mot de passe</div>
          <div class="item-source">Source : Impôts.gouv.fr</div>
          <div class="item-status none" id="status-p1"></div>
          <button type="button" class="comment-toggle" onclick="toggleComment('p1')">+ Ajouter un commentaire</button>
          <textarea class="comment-input" id="comment-p1" placeholder="Note ou précision…" oninput="saveComment('p1',this.value)"></textarea>
        </div>
      </div>
      <!-- p2 -->
      <div class="item-row" id="row-p2">
        <div class="item-check-area">
          <button type="button" class="check-btn" id="have-p2" onclick="toggleStatus('p2','have')"><div class="check-box"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><span>J'ai ce document</span></button>
          <button type="button" class="check-btn" id="missing-p2" onclick="toggleStatus('p2','missing')"><div class="check-box"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div><span>À retrouver</span></button>
