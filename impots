};
const MINI_GROUPS = {
  defis: ['i1','i2','i3','i4','i5'],
  nu: ['i6','i7','i8','i9','i10','i11'],
  meuble: ['i12','i13'],
  scpi: ['i14','i15','i16','i17'],
  av: ['f1'], per: ['f2'], gir: ['f3']
};

const state = {};
ALL_IDS.forEach(id => state[id] = {status: null, comment: ''});

// ===== TOGGLE CARD =====
function toggleCard(hdr) {
  const body = hdr.nextElementSibling;
  const chevron = hdr.querySelector('.cat-chevron');
  const isOpen = !body.classList.contains('closed');
  body.classList.toggle('closed', isOpen);
  chevron.classList.toggle('open', !isOpen);
}

// ===== TOGGLE STATUS =====
function toggleStatus(id, status) {
  state[id].status = state[id].status === status ? null : status;
  updateRowUI(id);
  updateStats();
  saveState();
}

function updateRowUI(id) {
  const s = state[id].status;
  const haveBtn = document.getElementById('have-'+id);
  const missingBtn = document.getElementById('missing-'+id);
  const statusEl = document.getElementById('status-'+id);
  haveBtn.className = 'check-btn' + (s === 'have' ? ' active-have' : '');
  missingBtn.className = 'check-btn' + (s === 'missing' ? ' active-missing' : '');
  if (s === 'have') { statusEl.className = 'item-status have'; statusEl.textContent = '✓ Document prêt'; }
  else if (s === 'missing') { statusEl.className = 'item-status missing'; statusEl.textContent = '✗ À retrouver'; }
  else { statusEl.className = 'item-status none'; statusEl.textContent = ''; }
}

// ===== COMMENT =====
function toggleComment(id) {
  const ta = document.getElementById('comment-'+id);
  ta.style.display = ta.style.display === 'block' ? 'none' : 'block';
  if (ta.style.display === 'block') ta.focus();
}
function saveComment(id, val) { state[id].comment = val; saveState(); }

// ===== STATS =====
function updateStats() {
  const total = ALL_IDS.length;
  const have = ALL_IDS.filter(id => state[id].status === 'have').length;
  const missing = ALL_IDS.filter(id => state[id].status === 'missing').length;
  const pending = total - have - missing;
  const pct = Math.round(((have + missing) / total) * 100);
  document.getElementById('total-count').textContent = total;
  document.getElementById('have-count').textContent = have;
  document.getElementById('missing-count').textContent = missing;
  document.getElementById('pending-count').textContent = pending;
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('progress-pct').textContent = pct + '% renseigné';
  // Mini bars
  Object.entries(MINI_GROUPS).forEach(([key, ids]) => {
    const done = ids.filter(id => state[id].status !== null).length;
    const p = Math.round((done / ids.length) * 100);
    const bar = document.getElementById('mini-'+key);
    const lbl = document.getElementById('mpct-'+key);
    if (bar) bar.style.width = p + '%';
    if (lbl) lbl.textContent = p + '%';
  });
}

// ===== SAVE/LOAD =====
function saveState() {
  try { localStorage.setItem('jlhChecklist2025', JSON.stringify(state)); } catch(e){}
}
function loadState() {
  try {
    const raw = localStorage.getItem('jlhChecklist2025');
    if (!raw) return;
    const saved = JSON.parse(raw);
    ALL_IDS.forEach(id => {
      if (saved[id]) { state[id].status = saved[id].status ?? null; state[id].comment = saved[id].comment ?? ''; }
    });
    ALL_IDS.forEach(id => {
      updateRowUI(id);
      if (state[id].comment) {
        const ta = document.getElementById('comment-'+id);
        if (ta) { ta.value = state[id].comment; }
      }
    });
    updateStats();
  } catch(e){}
}

// ===== MISSING PANEL =====
let missingVisible = false;
function toggleMissing() {
  const panel = document.getElementById('missing-panel');
  const list = document.getElementById('missing-list');
  const missingItems = ALL_IDS.filter(id => state[id].status === 'missing');
  list.innerHTML = '';
  if (missingItems.length === 0) {
    const li = document.createElement('li');
    li.textContent = 'Aucune pièce marquée comme manquante.';
    li.style.color = 'var(--green)'; li.style.fontStyle = 'italic';
    list.appendChild(li);
  } else {
    missingItems.forEach(id => {
      const li = document.createElement('li');
      const name = document.querySelector('#row-'+id+' .item-name').textContent;
      li.innerHTML = '<span style="flex:1">'+name+'</span><span class="missing-cat">'+CAT_LABELS[id]+'</span>';
      list.appendChild(li);
    });
  }
  missingVisible = !missingVisible;
  panel.style.display = missingVisible ? 'block' : 'none';
  if (missingVisible) panel.scrollIntoView({behavior:'smooth', block:'nearest'});
}

// ===== VALIDATE =====
function validatePrep() {
  const answered = ALL_IDS.filter(id => state[id].status !== null).length;
  if (answered === 0) { alert('Veuillez au moins renseigner une pièce avant de valider.'); return; }
  const panel = document.getElementById('success-panel');
  panel.style.display = 'block';
  panel.scrollIntoView({behavior:'smooth', block:'nearest'});
  saveState();
}

// ===== PDF =====
function escapeHtml(str) {
  return String(str||'').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}
function generatePDF() {
  const haveItems = ALL_IDS.filter(id => state[id].status === 'have');
  const missingItems = ALL_IDS.filter(id => state[id].status === 'missing');
  const pendingItems = ALL_IDS.filter(id => state[id].status === null);
  const today = new Date().toLocaleDateString('fr-FR', {day:'2-digit',month:'long',year:'numeric'});
  const getName = id => document.querySelector('#row-'+id+' .item-name')?.textContent || id;
  const getSource = id => { const s = document.querySelector('#row-'+id+' .item-source'); return s ? s.textContent.replace('Source : ','') : ''; };
  const renderList = (ids, emptyText) => {
    if (!ids.length) return '<p style="color:#6b7686;font-style:italic">'+emptyText+'</p>';
    return '<ul>'+ids.map(id => `<li><div><strong>${escapeHtml(getName(id))}</strong><div style="color:#6b7686;font-size:11px;margin-top:2px">${escapeHtml(CAT_LABELS[id])}${getSource(id) ? ' · '+escapeHtml(getSource(id)) : ''}</div>${state[id].comment ? '<div style="background:#E8EEF4;padding:4px 8px;border-radius:4px;font-size:11px;margin-top:4px">'+escapeHtml(state[id].comment)+'</div>' : ''}</div></li>`).join('')+'</ul>';
  };
  const html = `<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><title>Récapitulatif fiscal JLH</title>
  <style>*{box-sizing:border-box}body{font-family:Arial,sans-serif;margin:0;color:#142B45}.page{padding:20mm 16mm}.hdr{background:#142B45;color:white;padding:12mm 16mm;margin:-20mm -16mm 10mm}.brand{font-size:22px;font-weight:700}.brand span{color:#92A6BB}.sub{font-size:11px;color:#ADC0D1;text-transform:uppercase;letter-spacing:.1em;margin-top:4px}h1{font-size:20px;margin:0 0 4px}
  .muted{color:#6b7686;font-size:12px;margin-bottom:12px}.stats{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap}.stat{border:1px solid #D0DCE6;border-radius:8px;padding:8px 12px;min-width:100px;background:#F3F6F9}.stat .n{font-size:18px;font-weight:700}.green .n{color:#2E7D5B}.red .n{color:#C0392B}.sec{margin-top:16px}.sec h2{background:#142B45;color:white;font-size:13px;padding:6px 10px;border-radius:6px;margin:0 0 8px}ul{list-style:none;padding:0;margin:0}li{border-bottom:1px solid #D8E4ED;padding:6px 0}li:last-child{border-bottom:none}.ftr{margin-top:16px;padding-top:8px;border-top:1px solid #D0DCE6;color:#6b7686;font-size:10px}@media print{.page{padding-top:16mm}}</style></head>
  <body><div class="page"><div class="hdr"><div class="brand"><span>JLH</span> PATRIMOINE</div><div class="sub">Récapitulatif de préparation fiscale</div></div>
  <h1>Checklist fiscale client</h1><div class="muted">Édité le ${escapeHtml(today)} · Déclaration fiscale 2026</div>
  <div class="stats"><div class="stat"><div class="n">${ALL_IDS.length}</div><div>Total</div></div><div class="stat green"><div class="n">${haveItems.length}</div><div>Prêts</div></div><div class="stat red"><div class="n">${missingItems.length}</div><div>Manquants</div></div><div class="stat"><div class="n">${pendingItems.length}</div><div>Non renseignés</div></div></div>
  <div class="sec"><h2>✓ Documents identifiés</h2>${renderList(haveItems,'Aucune pièce marquée comme prête.')}</div>
  <div class="sec"><h2>✗ Pièces à retrouver</h2>${renderList(missingItems,'Aucune pièce manquante.')}</div>
  <div class="ftr">JLH Patrimoine · 19 boulevard Malesherbes, 75008 Paris · www.jlhpatrimoine.com</div></div>
  <script>window.onload=()=>{setTimeout(()=>window.print(),300);}<\/script></body></html>`;
  // Ouvrir dans nouvel onglet et déclencher l'impression (Ctrl+P / Enregistrer en PDF)
  const blob = new Blob([html], {type: 'text/html;charset=utf-8'});
  const url = URL.createObjectURL(blob);
  const w = window.open(url, '_blank');
  if (!w) {
    // fallback : iframe cachée
    const iframe = document.createElement('iframe');
    iframe.style.cssText = 'position:fixed;top:-9999px;left:-9999px;width:1px;height:1px;';
    iframe.src = url;
    document.body.appendChild(iframe);
    iframe.onload = () => {
      try { iframe.contentWindow.print(); } catch(e) {}
      setTimeout(() => { document.body.removeChild(iframe); URL.revokeObjectURL(url); }, 2000);
    };
  }
}

